<Window x:Class="WPF_MVVM_Sample.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_MVVM_Sample.Views"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:WPF_MVVM_Sample.Behaviors"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <i:Interaction.Behaviors>
        <behaviors:CloseWindowBehavior
            CloseRequest="{Binding NavHost.CloseRequest}" />
    </i:Interaction.Behaviors>
    
    <Grid>
        <ContentControl Content="{Binding NavHost.CurrentView.Value}" />
    </Grid>
</Window>
