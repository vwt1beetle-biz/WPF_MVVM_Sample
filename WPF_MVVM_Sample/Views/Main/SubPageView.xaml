<UserControl x:Class="WPF_MVVM_Sample.Views.SubPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_MVVM_Sample.Views"
             mc:Ignorable="d" 
             Background="White"
             FontFamily="Noto Sans JP"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="MainWindow SubPage"
                   Margin="8"
                   FontSize="18"
                   HorizontalAlignment="Center" />

        <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="前のページを開く" Command="{Binding NavPage.Value}" Margin="8" Padding="4" FontSize="14" />
            <Button Content="現在のWindowを閉じる" Command="{Binding CloseWindow.Value}" Margin="16" Padding="4" FontSize="14" />
        </StackPanel>
    </Grid>
</UserControl>
