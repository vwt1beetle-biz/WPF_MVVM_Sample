<UserControl x:Class="WPF_MVVM_Sample.Views.HomePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_MVVM_Sample.Views"
             mc:Ignorable="d" 
             Background="White"
             FontFamily="Noto Sans JP"
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0"
                   Text="MainWindow Home"
                   Margin="8"
                   FontSize="18"
                   HorizontalAlignment="Center" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="新しいWindowを開く" Command="{Binding ShowWindow1Command}" Margin="8" Padding="4" FontSize="14" />
                <Button Content="新しいWindowを開いて、現在のWindowを閉じる" Command="{Binding ShowWindow2Command}" Margin="8" Padding="4" FontSize="14" />
                <Button Content="新しいWindowを2ページ目Viewを指定して開く" Command="{Binding ShowWindow3Command}" Margin="8" Padding="4" FontSize="14" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="次のページを開く" Command="{Binding NavPageCommand}" Margin="8" Padding="4" FontSize="14" />
                <Button Content="現在のWindowを閉じる" Command="{Binding CloseCommand}" Margin="16" Padding="4" FontSize="14" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
